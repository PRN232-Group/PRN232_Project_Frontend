@startuml fig3_screenflow
!theme plain
skinparam shadowing false
skinparam backgroundColor white
skinparam ActivityBackgroundColor #F5F8FC
skinparam ActivityBorderColor #1F4E79

|Public / Guest|
start
:Home /;
:Products /products;
:Product detail /products/:id;
:Design gallery /design;
:Blog /blog;

|Customer|
:Cart /cart;
:Checkout /checkout;
:My orders /orders;
:Chat /chat;
:My quotations /my-quotations;
:My design requests /my-design-requests;

|Staff|
fork
  :Sales dashboard\n/sales/*;
fork again
  :Manager dashboard\n/manager/*;
fork again
  :Admin dashboard\n/admin/*;
end fork
stop
@enduml
