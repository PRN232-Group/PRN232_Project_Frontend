# Copy → .env.local for local overrides

# Mock UI (không cần backend).
# true  = luôn dùng mock
# false = luôn gọi API thật (cần VITE_API_BASE_URL)
# bỏ trống = mock tự bật nếu chưa có VITE_API_BASE_URL (phù hợp Vercel demo)
VITE_USE_MOCK=true

# Chỉ dùng khi VITE_USE_MOCK=false
VITE_API_BASE_URL=https://localhost:5001
